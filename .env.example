# Health Bot - Configuration Template
# Copia este archivo a .env y rellena los valores

# ========== TELEGRAM ==========
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ========== ANTHROPIC (Claude) ==========
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========== SUPABASE DATABASE ==========
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# ========== GARMIN (Sincronización de datos) ==========
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password_here

# ========== POLAR (Sincronización de datos) ==========
POLAR_CLIENT_ID=your_polar_client_id_here
POLAR_CLIENT_SECRET=your_polar_client_secret_here
POLAR_REDIRECT_URL=http://localhost:8000/auth/polar/callback

# ========== GROQ (Transcripción de audio) ==========
GROQ_API_KEY=your_groq_api_key_here

# ========== OPTIONAL: Logging & Debugging ==========
LOG_LEVEL=INFO
DEBUG_MODE=false
